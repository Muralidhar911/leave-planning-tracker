{
  "buildCommand": "pnpm install && pnpm --filter @workspace/leave-tracker run build:prod",
  "outputDirectory": "artifacts/leave-tracker/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
